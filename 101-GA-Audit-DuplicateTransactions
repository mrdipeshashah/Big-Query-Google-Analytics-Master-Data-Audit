SELECT
  -- 1. Where and How
  device.web_info.browser,
  device.category AS device_category,
  (SELECT value.string_value FROM UNNEST(event_params) WHERE key = 'page_location') AS page_url,
  
  -- 2. The Logic: Sessions with >1 Purchase
  COUNT(DISTINCT (SELECT value.int_value FROM UNNEST(event_params) WHERE key = 'ga_session_id')) AS sessions_with_doubles,
  
  -- 3. The Math: (Total Purchase Events) minus (Unique Sessions with Purchases)
  COUNT(*) - COUNT(DISTINCT (SELECT value.int_value FROM UNNEST(event_params) WHERE key = 'ga_session_id')) AS duplicate_count

FROM
  `enter.tablename_123456.events_*`
WHERE
  event_name = 'purchase'
  AND _TABLE_SUFFIX BETWEEN '20240101' AND '20251231'
GROUP BY 1, 2, 3
HAVING duplicate_count > 0
ORDER BY duplicate_count DESC
